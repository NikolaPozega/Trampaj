{
  "cli": {
    "version": ">= 13.0.0",
    "requireCommit": false
  },
  "build": {
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_DOMAIN": "trampaj.hr"
      }
    },
    "production": {
      "android": {
        "buildType": "app-bundle"
      },
      "ios": {
        "simulator": false
      },
      "env": {
        "EXPO_PUBLIC_DOMAIN": "trampaj.hr"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
