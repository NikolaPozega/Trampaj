# EAS Build upload ignore file
# EAS installs dependencies server-side — never upload node_modules
node_modules/

# Local Expo cache and build output
.expo/
dist/
web-build/

# Native build dirs (generated by EAS, not needed in upload)
android/
ios/

# Local dev server scripts (not part of the app bundle)
server/

# Misc large/unnecessary files
*.tsbuildinfo
npm-debug.*
yarn-debug.*
yarn-error.*
.DS_Store

# Local env overrides (secrets are passed via EAS secrets, not files)
.env*.local
