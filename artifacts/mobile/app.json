{
  "expo": {
    "name": "Trampaj.hr",
    "slug": "mobile",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mobile",
    "userInterfaceStyle": "dark",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#08152E"
    },
    "ios": {
      "supportsTablet": false
    },
    "android": {
      "backgroundColor": "#08152E",
      "package": "hr.trampaj.app",
      "googleServicesFile": "./google-services.json",
      "edgeToEdge": true
    },
    "web": {
      "favicon": "./assets/images/icon.png",
      "backgroundColor": "#08152E"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/203bae0a-78da-4e29-b5cc-9836e0ae481e"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-updates",
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#08152E",
          "defaultChannel": "poruke"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "baseUrl": "/mobile"
    },
    "extra": {
      "eas": {
        "projectId": "203bae0a-78da-4e29-b5cc-9836e0ae481e"
      }
    },
    "owner": "nikola1987"
  }
}