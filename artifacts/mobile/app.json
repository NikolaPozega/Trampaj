{
  "expo": {
    "name": "Trampaj.hr",
    "slug": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mobile",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#08152E"
    },
    "ios": {
      "supportsTablet": false
    },
    "android": {
      "backgroundColor": "#08152E"
    },
    "web": {
      "favicon": "./assets/images/icon.png",
      "backgroundColor": "#08152E"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#08152E",
          "defaultChannel": "poruke"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
